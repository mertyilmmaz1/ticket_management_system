rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Yardımcı fonksiyon: kullanıcı bu tenant'ın üyesi mi?
    function isTenantMember(tenantId) {
      return request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/tenants/$(tenantId)).data.memberUids;
    }

    // Yardımcı fonksiyon: kullanıcı bu tenant'ın sahibi mi?
    function isTenantOwner(tenantId) {
      return request.auth != null
        && get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerUid == request.auth.uid;
    }

    match /tenants/{tenantId} {
      // Okuma: sadece üyeler kendi tenant'larını görebilir
      // Liste sorgusu memberUids array-contains ile filtrelenir
      allow read: if request.auth != null
        && request.auth.uid in resource.data.memberUids;

      // Oluşturma: giriş yapmış kullanıcı, ownerUid ve memberUids zorunlu
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid
        && request.auth.uid in request.resource.data.memberUids
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0;

      // Güncelleme: sadece sahip
      allow update: if isTenantOwner(tenantId);

      // Silme: sadece sahip
      allow delete: if isTenantOwner(tenantId);

      // Alt koleksiyonlar: sadece tenant üyeleri erişebilir
      match /tables/{tableId} {
        allow read, write: if isTenantMember(tenantId);
      }
      match /categories/{categoryId} {
        allow read, write: if isTenantMember(tenantId);
      }
      match /products/{productId} {
        allow read, write: if isTenantMember(tenantId);
      }
      match /orders/{orderId} {
        allow read, write: if isTenantMember(tenantId);
      }
    }
  }
}
